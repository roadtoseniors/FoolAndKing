<ContentPage xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
             x:Class="FoolAndKing.Pages.CatalogBook">
        <Grid RowDefinitions="Auto,Auto,*">
        <StackPanel Grid.Row="0" Orientation="Horizontal" Spacing="12" Margin="16,16,16,8">
            <TextBox x:Name="SearchBox" Watermark="Поиск по названию или автору..." Width="260" TextChanged="OnSearchChanged"/>
            <ComboBox x:Name="SortBox" Width="160" SelectedIndex="0" SelectionChanged="OnSortChanged">
                <ComboBoxItem Content="По названию (А-Я)"/>
                <ComboBoxItem Content="По названию (Я-А)"/>
                <ComboBoxItem Content="По оценке (выше)"/>
                <ComboBoxItem Content="По оценке (ниже)"/>
            </ComboBox>
        </StackPanel>

        <ScrollViewer Grid.Row="1" HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Disabled" Margin="16,0,16,8">
            <ItemsControl x:Name="GenreFilter">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <StackPanel Orientation="Horizontal" Spacing="6"/>
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <ToggleButton Content="{Binding Name}" Tag="{Binding Id}" IsCheckedChanged="OnGenreToggled" Padding="10,4" CornerRadius="12"/>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>

        <ScrollViewer Grid.Row="2" Margin="16,0,16,16">
            <ItemsControl x:Name="BookGrid">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <WrapPanel Orientation="Horizontal"/>
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border BorderBrush="LightGray" BorderThickness="1" CornerRadius="8" Padding="10" Margin="0,0,12,12" Width="150" Background="White" Cursor="Hand">
                            <Border.Styles>
                                <Style Selector="Border:pointerover">
                                    <Setter Property="Background" Value="#F5F5F5"/>
                                </Style>
                            </Border.Styles>
                            <StackPanel Spacing="6">
                                <Border Height="90" CornerRadius="4" Background="WhiteSmoke" ClipToBounds="True">
                                    <Image Source="{Binding CoverPath}" Stretch="UniformToFill"/>
                                </Border>
                                <TextBlock Text="{Binding Name}" FontWeight="SemiBold" FontSize="12" TextWrapping="Wrap" MaxLines="2"/>
                                <TextBlock Text="{Binding Author.Name}" FontSize="11" Foreground="Gray"/>
                                <TextBlock Text="{Binding AverageScore, StringFormat='★ {0:0.0}'}" FontSize="11" Foreground="#E8A020"/>
                                <Grid ColumnDefinitions="*,Auto">
                                    <Button Grid.Column="0" Content="Открыть" FontSize="11" Padding="6,3" HorizontalAlignment="Stretch" Tag="{Binding}" Click="OnOpenBookClick"/>
                                    <Button Grid.Column="1" Content="+" FontSize="13" Padding="6,3" Margin="4,0,0,0" Tag="{Binding}" Click="OnAddToListClick" ToolTip.Tip="Добавить в список"/>
                                </Grid>
                            </StackPanel>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>
    </Grid>
</ContentPage>
