<ContentPage xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
             x:Class="FoolAndKing.Pages.AutorPage">
        <Grid RowDefinitions="Auto,*">
            <Border Grid.Row="0" BorderBrush="LightGray" BorderThickness="0,0,0,1" Padding="16,12">
                <Grid ColumnDefinitions="*,Auto">
                    <TextBlock Grid.Column="0" Text="Страница автора" FontSize="18" FontWeight="SemiBold" VerticalAlignment="Center"/>
                    <Button Grid.Column="1" Content="+ Добавить книгу" Padding="12,6" Click="OnAddBookClick"/>
                </Grid>
            </Border>
            <ScrollViewer Grid.Row="1">
                <StackPanel Margin="16,16" Spacing="24">
                    <StackPanel Spacing="10">
                        <TextBlock Text="Опубликованные книги" FontSize="15" FontWeight="SemiBold"/>
                        <TextBlock x:Name="NoBooksText" Text="У вас пока нет опубликованных книг." Foreground="Gray" FontSize="13" IsVisible="False"/>
                        <ItemsControl x:Name="ActiveBooksList">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <WrapPanel Orientation="Horizontal"/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border BorderBrush="LightGray" BorderThickness="1" CornerRadius="8" Padding="12" Margin="0,0,12,12" Width="180" Background="White">
                                        <StackPanel Spacing="6">
                                            <Border Height="90" CornerRadius="4" Background="WhiteSmoke" ClipToBounds="True">
                                                <Image Source="{Binding CoverPath}" Stretch="UniformToFill"/>
                                            </Border>
                                            <TextBlock Text="{Binding Name}" FontWeight="SemiBold" FontSize="13" TextWrapping="Wrap" MaxLines="2"/>
                                            <TextBlock Text="{Binding GenresText}" FontSize="11" Foreground="Gray" TextWrapping="Wrap"/>
                                            <TextBlock Text="{Binding AverageScore, StringFormat='Рейтинг {0:0.0}'}" FontSize="11" Foreground="#E8A020"/>
                                            <Button Content="Редактировать" FontSize="11" Padding="6,4" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center" Tag="{Binding}" Click="OnEditBookClick"/>
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>

                    <StackPanel Spacing="10">
                        <TextBlock Text="Замороженные книги" FontSize="15" FontWeight="SemiBold" Foreground="#C0392B"/>
                        <TextBlock x:Name="NoFrozenText" Text="Замороженных книг нет." Foreground="Gray" FontSize="13" IsVisible="False"/>
                        <ItemsControl x:Name="FrozenBooksList">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border BorderBrush="#F5C6C6" BorderThickness="1" CornerRadius="8" Padding="14" Margin="0,0,0,10" Background="#FFF8F8">
                                        <Grid ColumnDefinitions="*,Auto">
                                            <StackPanel Grid.Column="0" Spacing="4">
                                                <TextBlock Text="{Binding Name}" FontWeight="SemiBold" FontSize="14"/>
                                                <TextBlock Text="Книга заморожена администратором." Foreground="#C0392B" FontSize="12"/>
                                                <TextBlock Text="{Binding GenresText}" FontSize="11" Foreground="Gray"/>
                                            </StackPanel>
                                            <Button Grid.Column="1" Content="Оспорить" VerticalAlignment="Center" Padding="10,5" Tag="{Binding}" Click="OnAppealFrozenClick"/>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </StackPanel>
            </ScrollViewer>
        </Grid>
</ContentPage>
