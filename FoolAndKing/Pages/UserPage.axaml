<ContentPage xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
             x:Class="FoolAndKing.Pages.UserPage">
        <ScrollViewer>
        <StackPanel Margin="24,20" Spacing="20">

            <!-- Предупреждение о заморозке -->
            <Border x:Name="FrozenBanner" Background="#FFF3F3" BorderBrush="#F5C6C6" BorderThickness="1" CornerRadius="8" Padding="16" IsVisible="False">
                <StackPanel Spacing="10">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <TextBlock Text="Ваш аккаунт заморожен" FontSize="15" FontWeight="SemiBold" Foreground="#C0392B"/>
                    </StackPanel>
                    <TextBlock Text="Некоторые функции недоступны. Вы можете оспорить заморозку." Foreground="#C0392B" FontSize="13" TextWrapping="Wrap"/>

                    <!-- Форма оспаривания -->
                    <Border BorderBrush="#F5C6C6" BorderThickness="1"
                            CornerRadius="6" Padding="12" Background="White">
                        <StackPanel Spacing="8">
                            <TextBlock Text="Оспорить заморозку" FontWeight="Medium" Foreground="#333"/>
                            <TextBox x:Name="AppealText" Watermark="Опишите причину оспаривания..." AcceptsReturn="True" Height="70" TextWrapping="Wrap"/>
                            <Button x:Name="BtnAppeal" Content="Отправить заявку" HorizontalAlignment="Left" Click="OnAppealClick"/>
                            <TextBlock x:Name="AppealStatus" IsVisible="False" FontSize="12" TextWrapping="Wrap"/>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Border>

            <!-- Информация о пользователе -->
            <Border BorderBrush="LightGray" BorderThickness="1" CornerRadius="8" Padding="16">
                <StackPanel Spacing="12">
                    <TextBlock Text="Профиль" FontSize="16" FontWeight="SemiBold"/>

                    <Grid ColumnDefinitions="130,*" RowDefinitions="Auto,Auto,Auto,Auto" HorizontalAlignment="Left">
                        <TextBlock Grid.Row="0" Grid.Column="0" Text="Имя" Foreground="Gray" Margin="0,0,0,10"/>
                        <TextBlock Grid.Row="0" Grid.Column="1" x:Name="LblName" Margin="0,0,0,10"/>

                        <TextBlock Grid.Row="1" Grid.Column="0" Text="Логин" Foreground="Gray" Margin="0,0,0,10"/>
                        <TextBlock Grid.Row="1" Grid.Column="1" x:Name="LblLogin" Margin="0,0,0,10"/>

                        <TextBlock Grid.Row="2" Grid.Column="0" Text="Email" Foreground="Gray" Margin="0,0,0,10"/>
                        <TextBlock Grid.Row="2" Grid.Column="1" x:Name="LblEmail" Margin="0,0,0,10"/>

                        <TextBlock Grid.Row="3" Grid.Column="0" Text="Роль" Foreground="Gray"/>
                        <TextBlock Grid.Row="3" Grid.Column="1" x:Name="LblRole"/>
                    </Grid>
                </StackPanel>
            </Border>

            <!-- Заявка на роль автора -->
            <Border x:Name="AuthorRequestBlock" BorderBrush="LightGray" BorderThickness="1" CornerRadius="8" Padding="16" IsVisible="False">
                <StackPanel Spacing="10">
                    <TextBlock Text="Стать автором" FontSize="16" FontWeight="SemiBold"/>
                    <TextBlock Text="Подайте заявку, чтобы получить роль Автора и публиковать книги." Foreground="Gray" FontSize="13" TextWrapping="Wrap"/>
                    <TextBox x:Name="AuthorRequestText" Watermark="Расскажите о себе и почему хотите стать автором..." AcceptsReturn="True" Height="80" TextWrapping="Wrap"/>
                    <Button x:Name="BtnAuthorRequest" Content="Подать заявку на роль Автора" HorizontalAlignment="Left" Click="OnAuthorRequestClick"/>
                    <TextBlock x:Name="AuthorRequestStatus" IsVisible="False" FontSize="12" TextWrapping="Wrap"/>
                </StackPanel>
            </Border>

            <!-- Отзывы пользователя -->
            <StackPanel Spacing="10">
                <TextBlock Text="Мои отзывы" FontSize="16" FontWeight="SemiBold"/>
                <TextBlock x:Name="NoFeedbacksText" Text="У вас пока нет отзывов." Foreground="Gray" FontSize="13" IsVisible="False"/>
                <ItemsControl x:Name="UserFeedbacks">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border BorderBrush="LightGray" BorderThickness="1" CornerRadius="6" Padding="12" Margin="0,0,0,8">
                                <StackPanel Spacing="4">
                                    <StackPanel Orientation="Horizontal" Spacing="10">
                                        <TextBlock Text="{Binding BookName}" FontWeight="Medium"/>
                                        <TextBlock Text="{Binding Score, StringFormat='★ {0}'}" Foreground="#E8A020"/>
                                        <TextBlock Text="{Binding CreatedAt, StringFormat='{}{0:dd.MM.yyyy}'}" Foreground="Gray" FontSize="12" VerticalAlignment="Center"/>
                                    </StackPanel>
                                    <TextBlock Text="{Binding Text}" TextWrapping="Wrap" Foreground="#333" FontSize="13"/>
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>
        </StackPanel>
    </ScrollViewer>
</ContentPage>
